						<Condition><![CDATA[VarApuntar && (Llegada.count()==Salida.count())]]></Condition>
					</Properties>
					<Action><![CDATA[datasetTmed.add(dia, timeMeasureEnd.distribution.mean());
datasetLmed.add(dia, dataQueueSize.mean());
datasetProp.add(dia, 1-timeMeasureEnd.distribution.getCDF(10));
if (abd930){
datasetSal.add(dia, 1);
}else{
datasetSal.add(dia, 0);
}
VarApuntar=false;
if (dia==100){
	excelFile.writeDataSet(datasetTmed, 1, 1, 1);
	excelFile.writeDataSet(datasetLmed, 2, 1, 1);
	excelFile.writeDataSet(datasetProp, 3, 1, 1);
	excelFile.writeDataSet(datasetSal, 4, 1, 1);
}]]></Action>
