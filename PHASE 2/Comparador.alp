							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[false]]></Condition>
					</Properties>
					<Action><![CDATA[dia++;
timeMeasureEnd.distribution.reset();
dataQueueSize.reset();
abd930=true]]></Action>
				</Event>
