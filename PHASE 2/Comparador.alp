							<Value Class="CodeUnitValue">
								<Code><![CDATA[0;
	if (VarApuntar == false){
		_value=0.0482 + 0.0889 * agent.TiempoCompra +uniform(-0.0274, 0.0276);
	}else{
		_value=
		(
			(
				(0.0482 + 0.0889 * agent.TiempoCompra +uniform(-0.0274, 0.0276))
				-
				(0.0482 + 0.0889 * agent.TiempoCompraAcortado)
			)
			/
			(1.35+0.0482 + 0.0889 * agent.TiempoCompraAcortado)
		)
		+0.0482 + 0.0889 * agent.TiempoCompraAcortado;
	}
]]></Code>
								<Unit Class="TimeUnits"><![CDATA[HOUR]]></Unit>
