	<Experiments>	
		<!--   =========   Compare Runs Experiment   ========  -->
		<CompareRunsExperiment ActiveObjectClassId="1760106194690">
			<Id>1763045451918</Id>
			<Name><![CDATA[CompareRuns1]]></Name>
			<CommandLineArguments><![CDATA[]]></CommandLineArguments>
			<MaximumMemory>512</MaximumMemory>
			<RandomNumberGenerationType>randomSeed</RandomNumberGenerationType>
			<CustomGeneratorCode>new Random()</CustomGeneratorCode>
			<AfterSimulationRunCode><![CDATA[parametersOfRuns.add( new Object[] { E8_9, E8_10, E8_11, E8_12, E8_13, E8_14, E6_9, E6_10, E6_11, E6_12, E6_13, E6_14, E6_15, E6_16, E4_9, E4_10, E4_11, E4_12, E4_13, E4_14, E4_15, E4_16, E4_17, E4_18 } );
int numberOfRuns = getEngine().getRunCount();
Color color = spectrumColor( (numberOfRuns * 4) % 21, 21 );
while ( chart0.getCount() >= parametersOfRuns.size() ) {
	chart0.remove( chart0.getCount() - 1 );
}
chart0.addDataSet( root.datasetTmed, "Run " + numberOfRuns, color, true, Chart.INTERPOLATION_LINEAR, 1, Chart.POINT_NONE );
while ( chart1.getCount() >= parametersOfRuns.size() ) {
	chart1.remove( chart1.getCount() - 1 );
}
chart1.addDataSet( root.datasetLmed, "Run " + numberOfRuns, color, true, Chart.INTERPOLATION_LINEAR, 1, Chart.POINT_NONE );
while ( chart2.getCount() >= parametersOfRuns.size() ) {
	chart2.remove( chart2.getCount() - 1 );
}
chart2.addDataSet( root.datasetProp, "Run " + numberOfRuns, color, true, Chart.INTERPOLATION_LINEAR, 1, Chart.POINT_NONE );
while ( chart3.getCount() >= parametersOfRuns.size() ) {
	chart3.remove( chart3.getCount() - 1 );
}
chart3.addDataSet( root.datasetSal, "Run " + numberOfRuns, color, true, Chart.INTERPOLATION_LINEAR, 1, Chart.POINT_NONE );
while ( chart4.getCount() >= parametersOfRuns.size() ) {
	chart4.remove( chart4.getCount() - 1 );
}
DataItem chart4_item = new DataItem();
chart4_item.setValue( root.Tmed );
chart4.addDataItem( chart4_item, "Run " + numberOfRuns, color );
while ( chart5.getCount() >= parametersOfRuns.size() ) {
	chart5.remove( chart5.getCount() - 1 );
}
DataItem chart5_item = new DataItem();
chart5_item.setValue( root.Lmed );
chart5.addDataItem( chart5_item, "Run " + numberOfRuns, color );
while ( chart6.getCount() >= parametersOfRuns.size() ) {
	chart6.remove( chart6.getCount() - 1 );
}
DataItem chart6_item = new DataItem();
chart6_item.setValue( root.Prop );
chart6.addDataItem( chart6_item, "Run " + numberOfRuns, color );
while ( chart7.getCount() >= parametersOfRuns.size() ) {
	chart7.remove( chart7.getCount() - 1 );
}
DataItem chart7_item = new DataItem();
chart7_item.setValue( root.Sal );
chart7.addDataItem( chart7_item, "Run " + numberOfRuns, color );
]]></AfterSimulationRunCode>
