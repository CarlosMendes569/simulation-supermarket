					<Name><![CDATA[Apuntar]]></Name>
					<X>200</X><Y>290</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Properties TriggerType="condition" Mode="cyclic">
						<Timeout Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</Timeout>
						<Rate Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="RateUnits"><![CDATA[PER_DAY]]></Unit>
						</Rate>
						<Id>1761225312793</Id>
						<OccurrenceAtTime>true</OccurrenceAtTime>
						<OccurrenceDate>1761292800000</OccurrenceDate>
						<OccurrenceTime Class="CodeUnitValue">
							<Code><![CDATA[1380]]></Code>
							<Unit Class="TimeUnits"><![CDATA[MINUTE]]></Unit>
						</OccurrenceTime>
						<RecurrenceCode Class="CodeUnitValue">
							<Code><![CDATA[1]]></Code>
							<Unit Class="TimeUnits"><![CDATA[DAY]]></Unit>
						</RecurrenceCode>
						<Condition><![CDATA[VarApuntar && (Llegada.count()==Salida.count())]]></Condition>
					</Properties>
					<Action><![CDATA[datasetTmed.add(dia, timeMeasureEnd.distribution.mean());
datasetLmed.add(dia, dataQueueSize.mean());
datasetProp.add(dia, 1-timeMeasureEnd.distribution.getCDF(10));
if (abd930){
datasetSal.add(dia, 1);
}else{
datasetSal.add(dia, 0);
}
VarApuntar=false;
if (dia==50){
	Tmed=datasetTmed.getYMean();
	Lmed=datasetLmed.getYMean();
	Prop=datasetProp.getYMean();
	Sal=datasetSal.getYMean();
}]]></Action>
				</Event>
